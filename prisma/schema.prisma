generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Site {
  id          String  @id @default(uuid())
  slug        String  @unique
  name        String
  url         String  @unique
  description String?

  // SEO profile (populated by crawl + AI analysis)
  niche      String?
  audience   String?
  tone       String?
  topics     Json?
  seoProfile Json?   @map("seo_profile")

  // Branding
  logoUrl String? @map("logo_url")

  // Settings
  autopilot Boolean @default(false)

  // Publishing config (Phase 5)
  publishType   String? @map("publish_type")
  publishConfig Json?   @map("publish_config")

  // Status
  onboardingStatus String    @default("pending") @map("onboarding_status")
  lastCrawledAt    DateTime? @map("last_crawled_at")

  // Relations
  keywords     Keyword[]
  posts        Post[]
  jobs         JobQueue[]
  researchRuns ResearchRun[]
  usageEvents  UsageEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sites")
}

model Keyword {
  id     String @id @default(uuid())
  siteId String @map("site_id")
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  keyword        String
  searchVolume   Int?    @map("search_volume")
  difficulty     Float?
  cpc            Float?
  competition    String?
  intent         String?
  relevanceScore Float?  @map("relevance_score")

  // Clustering
  cluster   String?
  isPrimary Boolean @default(false) @map("is_primary")

  // Status
  status     String  @default("discovered")
  aiSelected Boolean @default(false) @map("ai_selected")

  // Relations
  posts Post[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([siteId, keyword])
  @@map("keywords")
}

model Post {
  id     String @id @default(uuid())
  siteId String @map("site_id")
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // Content
  title       String
  slug        String
  content     String
  excerpt     String?
  metaTitle   String? @map("meta_title")
  metaDesc    String? @map("meta_desc")
  featuredImg String? @map("featured_img")
  images      Json?
  humanized   Boolean @default(false)

  // SEO context
  keywordId String?  @map("keyword_id")
  keyword   Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  // Workflow
  status      String    @default("draft")
  reviewNotes String?   @map("review_notes")
  approvedBy  String?   @map("approved_by")
  approvedAt  DateTime? @map("approved_at")

  // Publishing (Phase 5)
  publishedAt  DateTime? @map("published_at")
  publishedUrl String?   @map("published_url")
  externalId   String?   @map("external_id")

  // Taxonomy (set by AI classification — slugs, platform-agnostic)
  category String?
  tags     String?

  // Generation metadata
  generatedBy   String? @map("generated_by")
  promptVersion String? @map("prompt_version")

  usageEvents UsageEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([siteId, slug])
  @@map("posts")
}

model JobQueue {
  id        String   @id @default(uuid())
  siteId    String   @map("site_id")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type      String
  status    String   @default("pending")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  usageEvents UsageEvent[]

  @@map("job_queue")
}

model ExchangeRate {
  date      DateTime @id @db.Date
  usdGbp    Decimal  @map("usd_gbp") @db.Decimal(10, 6)
  fetchedAt DateTime @default(now()) @map("fetched_at")

  @@map("exchange_rates")
}

model ResearchRun {
  id                  String    @id @default(uuid())
  siteId              String    @map("site_id")
  site                Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  startedAt           DateTime  @default(now()) @map("started_at")
  completedAt         DateTime? @map("completed_at")
  status              String    @default("running")
  keywordsDiscovered  Int       @default(0) @map("keywords_discovered")
  keywordsScored      Int       @default(0) @map("keywords_scored")
  keywordsAiPicked    Int       @default(0) @map("keywords_ai_picked")
  triggeredByUserId   String?   @map("triggered_by_user_id")

  usageEvents UsageEvent[]

  @@index([siteId, startedAt(sort: Desc)])
  @@map("research_runs")
}

model UsageEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  provider  String
  model     String?
  operation String

  inputTokens   Int? @map("input_tokens")
  outputTokens  Int? @map("output_tokens")
  wordCount     Int? @map("word_count")
  imageCount    Int? @map("image_count")
  apiCallCount  Int? @map("api_call_count")

  costUsd      Decimal @map("cost_usd")      @db.Decimal(10, 6)
  costGbp      Decimal @map("cost_gbp")      @db.Decimal(10, 6)
  exchangeRate Decimal @map("exchange_rate") @db.Decimal(10, 6)

  siteId         String?      @map("site_id")
  site           Site?        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  postId         String?      @map("post_id")
  post           Post?        @relation(fields: [postId], references: [id], onDelete: SetNull)
  researchRunId  String?      @map("research_run_id")
  researchRun    ResearchRun? @relation(fields: [researchRunId], references: [id], onDelete: SetNull)
  jobId          String?      @map("job_id")
  job            JobQueue?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  metadata     Json?
  durationMs   Int?    @map("duration_ms")
  errorMessage String? @map("error_message")

  @@index([postId])
  @@index([siteId])
  @@index([researchRunId])
  @@index([createdAt(sort: Desc)])
  @@index([provider])
  @@map("usage_events")
}
