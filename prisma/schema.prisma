generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Site {
  id          String  @id @default(uuid())
  slug        String  @unique
  name        String
  url         String  @unique
  description String?

  // SEO profile (populated by crawl + AI analysis)
  niche      String?
  audience   String?
  tone       String?
  topics     Json?
  seoProfile Json?   @map("seo_profile")

  // Settings
  autopilot Boolean @default(false)

  // Publishing config (Phase 5)
  publishType   String? @map("publish_type")
  publishConfig Json?   @map("publish_config")

  // Status
  onboardingStatus String    @default("pending") @map("onboarding_status")
  lastCrawledAt    DateTime? @map("last_crawled_at")

  // Relations
  keywords Keyword[]
  posts    Post[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sites")
}

model Keyword {
  id     String @id @default(uuid())
  siteId String @map("site_id")
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  keyword        String
  searchVolume   Int?    @map("search_volume")
  difficulty     Float?
  cpc            Float?
  competition    String?
  intent         String?
  relevanceScore Float?  @map("relevance_score")

  // Clustering
  cluster   String?
  isPrimary Boolean @default(false) @map("is_primary")

  // Status
  status String @default("discovered")

  // Relations
  posts Post[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([siteId, keyword])
  @@map("keywords")
}

model Post {
  id     String @id @default(uuid())
  siteId String @map("site_id")
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // Content
  title       String
  slug        String
  content     String
  excerpt     String?
  metaTitle   String? @map("meta_title")
  metaDesc    String? @map("meta_desc")
  featuredImg String? @map("featured_img")

  // SEO context
  keywordId String?  @map("keyword_id")
  keyword   Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  // Workflow
  status      String    @default("draft")
  reviewNotes String?   @map("review_notes")
  approvedBy  String?   @map("approved_by")
  approvedAt  DateTime? @map("approved_at")

  // Publishing (Phase 5)
  publishedAt  DateTime? @map("published_at")
  publishedUrl String?   @map("published_url")
  externalId   String?   @map("external_id")

  // Generation metadata
  generatedBy   String? @map("generated_by")
  promptVersion String? @map("prompt_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([siteId, slug])
  @@map("posts")
}
